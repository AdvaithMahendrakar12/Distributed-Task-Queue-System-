generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Job {
  id            String    @id
  type          String    
  payload       Json      
  status        String    
  workerId      String? 
  retryCount    Int      
  errorMessage  String?   
  createdAt     DateTime  
  startedAt     DateTime? 
  completedAt   DateTime? 
}

